<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Color Cognition Trainer</title>

<style>

body{
font-family:Arial;
background:#111;
color:white;
text-align:center;
margin:0;
}

button{
padding:10px 20px;
margin:10px;
font-size:16px;
cursor:pointer;
}

#colorDisplay{
width:100vw;
height:100vh;
position:fixed;
top:0;
left:0;
display:none;
z-index:10;
}

#game{
padding-top:40px;
}

.slider{
width:300px;
}

#feedback{
font-size:30px;
margin-top:20px;
}

#score{
font-size:22px;
}

.flash{
position:fixed;
top:0;
left:0;
width:100vw;
height:100vh;
pointer-events:none;
z-index:15;
}

</style>
</head>

<body>

<h1>Color Cognition Trainer</h1>

<div>

<button onclick="startGame()">Recrear Color</button>
<button onclick="startSimon()">Simon Says</button>

<br>

<label>
<input type="checkbox" id="hardmode">
Modo Difícil (flashes)
</label>

<br>

<label>
<input type="checkbox" id="confidenceMode">
Confidence Bet
</label>

</div>

<div id="score">Score: 0</div>

<div id="game" style="display:none;">

<div>

Hue<br>
<input class="slider" id="hue" type="range" min="0" max="360">

<br>

Saturation<br>
<input class="slider" id="sat" type="range" min="0" max="100">

<br>

Brightness<br>
<input class="slider" id="bri" type="range" min="0" max="100">

</div>

<br>

<div id="confidenceUI" style="display:none">

Confidence

<select id="confidence">
<option value="0.5">50%</option>
<option value="0.7">70%</option>
<option value="0.9">90%</option>
<option value="1">100%</option>
</select>

</div>

<br>

<button onclick="submitGuess()">Submit</button>

<div id="feedback"></div>

</div>

<div id="colorDisplay"></div>

<script>

let targetColor
let score=0

function randomColor(){

return{
h:Math.floor(Math.random()*360),
s:Math.floor(Math.random()*100),
b:Math.floor(Math.random()*100)
}

}

function hsbToRgb(h,s,v){

s/=100
v/=100

let c=v*s
let x=c*(1-Math.abs((h/60)%2-1))
let m=v-c

let r=0,g=0,b=0

if(h<60){r=c;g=x}
else if(h<120){r=x;g=c}
else if(h<180){g=c;b=x}
else if(h<240){g=x;b=c}
else if(h<300){r=x;b=c}
else{r=c;b=x}

r=Math.round((r+m)*255)
g=Math.round((g+m)*255)
b=Math.round((b+m)*255)

return `rgb(${r},${g},${b})`

}

function startGame(){

document.getElementById("game").style.display="block"

targetColor=randomColor()

let display=document.getElementById("colorDisplay")

display.style.background=hsbToRgb(targetColor.h,targetColor.s,targetColor.b)

display.style.display="block"

if(document.getElementById("hardmode").checked){

flashChaos()

}

setTimeout(()=>{

display.style.display="none"

},5000)

if(document.getElementById("confidenceMode").checked){

document.getElementById("confidenceUI").style.display="block"

}

}

function flashChaos(){

let flashes=10

let interval=setInterval(()=>{

let flash=document.createElement("div")

flash.className="flash"

let types=["white","black","gradient"]

let type=types[Math.floor(Math.random()*3)]

if(type=="white")flash.style.background="white"
if(type=="black")flash.style.background="black"
if(type=="gradient")flash.style.background="linear-gradient(red,blue)"

flash.style.opacity=Math.random()*0.4

document.body.appendChild(flash)

setTimeout(()=>flash.remove(),150)

flashes--

if(flashes<=0)clearInterval(interval)

},400)

}

function submitGuess(){

let h=document.getElementById("hue").value
let s=document.getElementById("sat").value
let b=document.getElementById("bri").value

let diff=
Math.abs(h-targetColor.h)+
Math.abs(s-targetColor.s)+
Math.abs(b-targetColor.b)

let accuracy=100-(diff/5)

if(accuracy<0)accuracy=0

let feedback=""

if(accuracy>98)feedback="PERFECT MEMORY"
else if(accuracy>90)feedback="NEAR MISS"
else if(accuracy<40)feedback="PISS OFF"
else feedback="Decent"

let multiplier=1

if(document.getElementById("confidenceMode").checked){

let conf=parseFloat(document.getElementById("confidence").value)

accuracy*=conf

}

if(
Math.round(h)==targetColor.h ||
Math.round(s)==targetColor.s ||
Math.round(b)==targetColor.b
){

multiplier=1.05

}else{

multiplier=0.95

}

let gained=Math.floor(accuracy*multiplier)

score+=gained

document.getElementById("score").innerText="Score: "+score

document.getElementById("feedback").innerText=
feedback+" | "+accuracy.toFixed(1)+"% | +"+gained

}

function startSimon(){

let sequence=[]
let round=1

function nextRound(){

if(round>3){

alert("Simon completado")

return

}

sequence=[]

for(let i=0;i<round;i++){

sequence.push(randomColor())

}

showSequence(sequence,0)

}

function showSequence(seq,i){

if(i>=seq.length){

setTimeout(()=>playerTurn(seq),500)

return

}

let display=document.getElementById("colorDisplay")

display.style.display="block"

display.style.background=hsbToRgb(seq[i].h,seq[i].s,seq[i].b)

setTimeout(()=>{

display.style.display="none"

setTimeout(()=>showSequence(seq,i+1),500)

},1000)

}

function playerTurn(seq){

let index=0

alert("Reproduce los colores con los sliders")

function check(){

let h=document.getElementById("hue").value
let s=document.getElementById("sat").value
let b=document.getElementById("bri").value

let target=seq[index]

let diff=
Math.abs(h-target.h)+
Math.abs(s-target.s)+
Math.abs(b-target.b)

if(diff<60){

index++

if(index>=seq.length){

round++

nextRound()

}

}else{

alert("Fallaste Simon")

}

}

document.querySelector("#game button").onclick=check

}

nextRound()

}

</script>

</body>
</html>
